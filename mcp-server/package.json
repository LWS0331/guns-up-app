{
  "name": "gunnyai-trainer-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that exposes a trainer's gunnyai.fit account to Claude.ai. Lets RAMPAGE + VALKYRIE drive their own training data from Claude.ai's subscription chat — zero Anthropic spend on our infra.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "express": "^5.0.1",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
