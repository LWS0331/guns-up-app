generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Operator {
  id          String   @id           // e.g. "op-ruben"
  name        String
  callsign    String
  pin         String
  email       String?   @unique
  passwordHash String?
  role        String                  // "trainer" | "client"
  tier        String                  // "haiku" | "sonnet" | "opus" | "white_glove"
  coupleWith  String?
  trainerId   String?
  clientIds   String[]  @default([])
  trainerNotes String?
  betaUser    Boolean   @default(false)
  betaFeedback String[] @default([])
  betaStartDate String?               // ISO date when beta started
  betaEndDate   String?               // ISO date when beta expires (45 days)
  isVanguard    Boolean  @default(false) // founding member status
  tierLocked    Boolean  @default(false) // post-launch: tier cannot be changed
  promoActive   Boolean  @default(false) // currently on promotional period
  promoType     String?               // e.g. "free_month_recon"
  promoExpiry   String?               // ISO date when promo expires

  // Complex nested data stored as JSONB
  intake      Json      @default("{}")  // IntakeAssessment (completed flag, goals, equipment, etc.)
  profile     Json      @default("{}")
  nutrition   Json      @default("{}")
  prs         Json      @default("[]")
  injuries    Json      @default("[]")
  preferences Json      @default("{}")
  workouts    Json      @default("{}")  // Record<string, Workout>
  dayTags     Json      @default("{}")  // Record<string, DayTag>
  sitrep      Json      @default("{}")  // Sitrep battle plan from Gunny AI
  dailyBrief  Json      @default("{}")  // Today's adaptive daily brief
  billing     Json      @default("{}")  // Stripe billing data

  // Junior Operator fields (gated behind JUNIOR_OPERATOR_ENABLED feature flag)
  isJunior      Boolean  @default(false)
  juniorAge     Int?                                  // duplicate of profile.age for fast filter
  parentIds     String[] @default([])                 // adult operators with full visibility
  sportProfile  Json     @default("{}")               // SportProfile shape — see src/lib/types.ts
  juniorConsent Json     @default("{}")               // parent consent record + signed dates
  juniorSafety  Json     @default("{}")               // refusal log, escalation flags, RED-S flags

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([parentIds])
  @@index([isJunior])
}

model ChatHistory {
  id          String   @id @default(cuid())
  operatorId  String
  chatType    String                  // "gunny-tab" | "gunny-panel" | "gunny-onboarding"
  messages    Json     @default("[]") // Array of chat messages
  updatedAt   DateTime @updatedAt

  @@unique([operatorId, chatType])
}

model WearableConnection {
  id              String   @id @default(cuid())
  operatorId      String
  vitalUserId     String                  // Junction/Vital user UUID
  provider        String                  // e.g. "oura", "whoop_v2", "garmin", "fitbit"
  providerName    String                  // Display name e.g. "Oura Ring"
  connectedAt     DateTime @default(now())
  lastSyncAt      DateTime?
  syncData        Json     @default("{}") // Latest health metrics snapshot
  active          Boolean  @default(true)

  @@unique([operatorId, provider])
  @@index([operatorId])
  @@index([vitalUserId])
}

// Trainer applications submitted via /trainer-apply landing page form.
// Public POST endpoint; admin-only GET. Reviewed manually — no auto-acceptance.
// Migration NOT run automatically; apply via `prisma migrate dev` when ready.
model TrainerApplication {
  id                  String   @id @default(cuid())
  email               String
  name                String
  callsign            String?                // optional — applicant may not have a callsign yet
  yearsCertified      Int                    // years holding any S&C / personal-training cert
  currentClientCount  Int                    // active paying clients today
  primaryDiscipline   String                 // e.g. "strength", "hypertrophy", "tactical", "sport_perf"
  certifications      String[] @default([])  // e.g. ["NSCA-CSCS", "NASM-CPT"]
  whyGunsUp           String                 // free text — qualifying motivation
  sampleProgramming   String                 // free text — sample week / proof-of-craft

  status              String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy          String?                // operatorId of admin who reviewed (e.g. "op-ruben")
  reviewedAt          DateTime?
  reviewNotes         String?

  // Spam-protection metadata (mirrors /api/contact rate-limit pattern)
  ip                  String?
  userAgent           String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([email])
}
