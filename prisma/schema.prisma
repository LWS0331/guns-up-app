generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Operator {
  id          String   @id           // e.g. "op-ruben"
  name        String
  callsign    String
  pin         String
  email       String?   @unique
  passwordHash String?
  googleId    String?   @unique  // Google OAuth `sub` claim — set after first sign-in via /api/auth/google/callback
  role        String                  // "trainer" | "client"
  tier        String                  // "haiku" | "sonnet" | "opus" | "white_glove"
  // AI coach persona — see src/lib/personas.ts. NULL or unknown values
  // resolve to 'gunny' via resolvePersonaId() (legacy default).
  personaId   String?                  // "gunny" | "raven" | "buck" | "coach"
  coupleWith  String?
  trainerId   String?
  clientIds   String[]  @default([])
  trainerNotes String?
  betaUser    Boolean   @default(false)
  betaFeedback String[] @default([])
  betaStartDate String?               // ISO date when beta started
  betaEndDate   String?               // ISO date when beta expires (45 days)
  isVanguard    Boolean  @default(false) // founding member status
  tierLocked    Boolean  @default(false) // post-launch: tier cannot be changed
  promoActive   Boolean  @default(false) // currently on promotional period
  promoType     String?               // e.g. "free_month_recon"
  promoExpiry   String?               // ISO date when promo expires

  // Complex nested data stored as JSONB
  intake      Json      @default("{}")  // IntakeAssessment (completed flag, goals, equipment, etc.)
  profile     Json      @default("{}")
  nutrition   Json      @default("{}")
  prs         Json      @default("[]")
  injuries    Json      @default("[]")
  preferences Json      @default("{}")
  workouts    Json      @default("{}")  // Record<string, Workout>
  dayTags     Json      @default("{}")  // Record<string, DayTag>
  dailyReadiness Json   @default("{}")  // Record<string, DailyReadinessEntry> — daily check-ins (sleep/stress/mood/readiness/energy)
  sitrep      Json      @default("{}")  // Sitrep battle plan from Gunny AI
  dailyBrief  Json      @default("{}")  // Today's adaptive daily brief
  billing     Json      @default("{}")  // Stripe billing data

  // Macrocycle engine (Apr 2026). Up to 2 active goals — calendar-aware
  // periodization for 6-12 month targets. See src/lib/macrocycle.ts and
  // src/lib/macrocycleLibrary.ts. Migration NOT auto-run.
  macroCycles  Json     @default("[]")    // MacroCycle[] — see src/lib/types.ts

  // Junior Operator fields (gated behind JUNIOR_OPERATOR_ENABLED feature flag)
  isJunior      Boolean  @default(false)
  juniorAge     Int?                                  // duplicate of profile.age for fast filter
  parentIds     String[] @default([])                 // adult operators with full visibility
  sportProfile  Json     @default("{}")               // SportProfile shape — see src/lib/types.ts
  juniorConsent Json     @default("{}")               // parent consent record + signed dates
  juniorSafety  Json     @default("{}")               // refusal log, escalation flags, RED-S flags

  // Free RECON usage caps (Pricing Strategy v2 — RECON is now $0/mo with
  // hard caps to prevent runaway API spend). Tiers above RECON ignore.
  // Counters reset against rolling windows: chats every 24h, workout
  // generations every 7 days. See src/lib/usageCaps.ts.
  reconChatsCount       Int       @default(0)         // chats in current 24h window
  reconChatsResetAt     DateTime?                     // next reset boundary (now + 24h)
  reconWorkoutsCount    Int       @default(0)         // workout generations in current 7d window
  reconWorkoutsResetAt  DateTime?                     // next reset boundary (now + 7d)

  // Post-purchase activation tracking (PaywallSpec §8). The cron in
  // src/app/api/cron/activation-emails/route.ts scans these fields to
  // schedule the four-email activation sequence (immediate, 6h, 3d, 7d).
  webPurchaseAt           DateTime?  // first Stripe webhook fired for this account
  firstAppOpenAt          DateTime?  // first authenticated app session
  firstWorkoutCompletedAt DateTime?  // first workout marked done after activation
  activationEmailsSent    Int        @default(0)
  lastActivationEmailAt   DateTime?
  passwordResetRequestedAt DateTime?
  recoveryAttempts         Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([parentIds])
  @@index([isJunior])
  @@index([webPurchaseAt, firstAppOpenAt])  // activation email cron scan
}

// OperatorBaseline — rolling-window personal baselines for the
// autoregulation engine. Updated daily by /api/cron/baselines from
// recent Workouts + WearableConnection.syncData. Read by
// src/lib/readiness.ts to compute the GO_HARD / NORMAL / DELOAD /
// REST recommendation with confidence-graded output.
//
// Cold-start protocol (per "RPE auto-regulation engine" v1 spec):
//   - Days 0-6: function returns INSUFFICIENT_DATA, falls back to
//     existing recovery-readout hardcoded thresholds.
//   - Days 7-13: low-confidence recommendations (DELOAD nudges only,
//     no STOP-style rest calls).
//   - Days 14+: full personal-baseline engine.
//
// All fields nullable so a fresh row can be created at first sync
// before any rolling means exist.
model OperatorBaseline {
  operatorId       String   @id
  hrvRollingMean   Float?   // 14-day rolling mean (ms)
  hrvRollingSD     Float?
  rhrRollingMean   Float?   // resting HR (bpm)
  sleepHoursMean   Float?
  sRpeMean         Float?
  sRpeSD           Float?
  acuteLoad7d      Float?   // sum of (sRPE × durationMin) over last 7d
  chronicLoad28d   Float?   // rolling 28d mean of daily loads
  acwr             Float?   // acute / chronic — sweet spot 0.8-1.3
  baselineDays     Int      @default(0)  // days of data contributing
  lastComputedAt   DateTime?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@index([lastComputedAt])
}

// AuthToken — short-lived single-use tokens for the activation flow.
// Three intents:
//   - web_handoff:    iOS app generates a token to hand off to the web
//                     for an upgrade checkout. 5-min TTL, single use.
//   - magic_link:     emailed sign-in link sent post-purchase. 7-day TTL.
//   - password_reset: standard password recovery. 1-hour TTL.
// metadata holds intent-specific payload (e.g. targetTier for upgrades).
model AuthToken {
  id          String    @id @default(cuid())
  operatorId  String
  type        String    // 'web_handoff' | 'magic_link' | 'password_reset'
  intent      String?   // 'upgrade' | 'sign_in' | 'recover'
  metadata    Json      @default("{}")
  used        Boolean   @default(false)
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([operatorId])
  @@index([expiresAt])
}

model ChatHistory {
  id          String   @id @default(cuid())
  operatorId  String
  chatType    String                  // "gunny-tab" | "gunny-panel" | "gunny-onboarding"
  messages    Json     @default("[]") // Array of chat messages
  updatedAt   DateTime @updatedAt

  @@unique([operatorId, chatType])
}

model WearableConnection {
  id              String   @id @default(cuid())
  operatorId      String
  vitalUserId     String                  // Junction/Vital user UUID
  provider        String                  // e.g. "oura", "whoop_v2", "garmin", "fitbit"
  providerName    String                  // Display name e.g. "Oura Ring"
  connectedAt     DateTime @default(now())
  lastSyncAt      DateTime?
  syncData        Json     @default("{}") // Latest health metrics snapshot
  active          Boolean  @default(true)

  @@unique([operatorId, provider])
  @@index([operatorId])
  @@index([vitalUserId])
}

// WearableSnapshot — one row per operator per calendar day, written
// by /api/wearables/webhook on each daily.data.* event (and by the
// sync route's pull). Lets the baselines cron compute TRUE rolling
// means/SDs from real historical samples instead of the v1
// approximation that treated each cron run as one data point against
// an incrementally-updated mean.
//
// The unique([operatorId, syncDate]) lets the webhook upsert by
// (operator, day) so a provider that pushes multiple events for the
// same day (sleep + recovery + body) collapses to a single row, with
// each event filling in its own columns via the Prisma `update` half.
//
// Migration NOT run automatically; applies via Prisma's runtime
// `db push` at deploy startup (see scripts/start.* and migrate route).
model WearableSnapshot {
  id              String   @id @default(cuid())
  operatorId      String
  syncDate        String                  // calendar_date YYYY-MM-DD (provider-reported)
  hrv             Float?                  // ms
  restingHr       Float?                  // bpm
  sleepHours      Float?                  // hours (decimal) — stored consistently with webhook/sync output
  sleepEfficiency Float?                  // 0-100
  recoveryScore   Float?                  // 0-100 (provider-computed when present)
  raw             Json     @default("{}") // last full provider payload for the day, for debugging
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([operatorId, syncDate])
  @@index([operatorId, syncDate])
}

// Trainer applications submitted via /trainer-apply landing page form.
// Public POST endpoint; admin-only GET. Reviewed manually — no auto-acceptance.
// Migration NOT run automatically; apply via `prisma migrate dev` when ready.
// Junior Operator beta-list signups (May 2026, /junior-operator
// landing). Public form takes role + email + name + an optional
// "lifter experience" follow-up. We onboard in waves; status flips
// from "pending" → "invited" once an admin sends the magic link
// from the founder dashboard. Same shape as TrainerApplication so
// the admin tooling can be unified later.
model JuniorBetaLead {
  id                  String   @id @default(cuid())
  email               String
  name                String
  // "parent" | "coach" | "athlete" | "lifter" — discriminator that
  // routes the lead into the right onboarding bucket.
  role                String
  // Free-form context only meaningful when role === "lifter"
  // ("2 years · novice · serious", etc.). NULL for other roles.
  lifterExperience    String?

  status              String   @default("pending")  // "pending" | "invited" | "rejected"
  reviewedBy          String?                       // operatorId of admin who reviewed
  reviewedAt          DateTime?
  reviewNotes         String?

  // Spam-protection metadata (mirrors /api/trainer-applications)
  ip                  String?
  userAgent           String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([role])
}

model TrainerApplication {
  id                  String   @id @default(cuid())
  email               String
  name                String
  callsign            String?                // optional — applicant may not have a callsign yet
  yearsCertified      Int                    // years holding any S&C / personal-training cert
  currentClientCount  Int                    // active paying clients today
  primaryDiscipline   String                 // e.g. "strength", "hypertrophy", "tactical", "sport_perf"
  certifications      String[] @default([])  // e.g. ["NSCA-CSCS", "NASM-CPT"]
  whyGunsUp           String                 // free text — qualifying motivation
  sampleProgramming   String                 // free text — sample week / proof-of-craft

  status              String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy          String?                // operatorId of admin who reviewed (e.g. "op-ruben")
  reviewedAt          DateTime?
  reviewNotes         String?

  // Spam-protection metadata (mirrors /api/contact rate-limit pattern)
  ip                  String?
  userAgent           String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([email])
}
