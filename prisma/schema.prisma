generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Operator {
  id          String   @id           // e.g. "op-ruben"
  name        String
  callsign    String
  pin         String
  role        String                  // "trainer" | "client"
  tier        String                  // "haiku" | "sonnet" | "opus" | "white_glove"
  coupleWith  String?
  trainerId   String?
  clientIds   String[]  @default([])
  trainerNotes String?
  betaUser    Boolean   @default(false)
  betaFeedback String[] @default([])
  betaStartDate String?               // ISO date when beta started
  betaEndDate   String?               // ISO date when beta expires (45 days)
  isVanguard    Boolean  @default(false) // founding member status
  tierLocked    Boolean  @default(false) // post-launch: tier cannot be changed
  promoActive   Boolean  @default(false) // currently on promotional period
  promoType     String?               // e.g. "free_month_recon"
  promoExpiry   String?               // ISO date when promo expires

  // Complex nested data stored as JSONB
  profile     Json      @default("{}")
  nutrition   Json      @default("{}")
  prs         Json      @default("[]")
  injuries    Json      @default("[]")
  preferences Json      @default("{}")
  workouts    Json      @default("{}")  // Record<string, Workout>
  dayTags     Json      @default("{}")  // Record<string, DayTag>
  billing     Json      @default("{}")  // Stripe billing data

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ChatHistory {
  id          String   @id @default(cuid())
  operatorId  String
  chatType    String                  // "gunny-tab" | "gunny-panel" | "gunny-onboarding"
  messages    Json     @default("[]") // Array of chat messages
  updatedAt   DateTime @updatedAt

  @@unique([operatorId, chatType])
}

model WearableConnection {
  id              String   @id @default(cuid())
  operatorId      String
  vitalUserId     String                  // Junction/Vital user UUID
  provider        String                  // e.g. "oura", "whoop_v2", "garmin", "fitbit"
  providerName    String                  // Display name e.g. "Oura Ring"
  connectedAt     DateTime @default(now())
  lastSyncAt      DateTime?
  syncData        Json     @default("{}") // Latest health metrics snapshot
  active          Boolean  @default(true)

  @@unique([operatorId, provider])
  @@index([operatorId])
  @@index([vitalUserId])
}
